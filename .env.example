# ─────────────────────────────────────────────
#  MemTrace — Environment Variables Template
#  Copy to .env and fill in your own values.
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memtrace
POSTGRES_USER=memtrace
POSTGRES_PASSWORD=your_password_here

# Derived connection string (used by API)
DATABASE_URL=postgresql://memtrace:your_password_here@localhost:5432/memtrace

# ─── API Security ──────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_random_64_char_hex_string

# JWT token lifetime (days)
ACCESS_TOKEN_EXPIRE_DAYS=7

# ─── Google OAuth (optional) ───────────────────
# Leave blank to disable Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ─── Managed AI Credits ────────────────────────
# Server-level keys used when a user has no personal key.
# Leave blank to disable managed free tier (users must bring their own keys).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Free token budget per user per month (default 50 000)
AI_FREE_TOKEN_LIMIT=50000
