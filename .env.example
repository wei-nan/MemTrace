# ─────────────────────────────────────────────
#  MemTrace — Environment Variables Template
#  Copy to .env and fill in your own values.
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memtrace
POSTGRES_USER=memtrace
POSTGRES_PASSWORD=your_password_here

# Derived connection string (used by API)
DATABASE_URL=postgresql://memtrace:your_password_here@localhost:5432/memtrace

# ─── API Security ──────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_random_64_char_hex_string

# JWT token lifetime (days)
ACCESS_TOKEN_EXPIRE_DAYS=7

# ─── Managed AI Credits ────────────────────────
# Server-level keys used when a user has no personal key.
# Leave blank to disable managed free tier (users must bring their own keys).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Free token budget per user per month (default 50 000)
AI_FREE_TOKEN_LIMIT=50000

# ─── Email ─────────────────────────────────────────────────────────────────────
# Provider: "resend" | "smtp" | "disabled"
# "disabled" → tokens printed to console (development only, no actual emails sent)
EMAIL_PROVIDER=disabled

# Resend (https://resend.com — recommended)
# Steps:
#   1. Sign up at resend.com → create an API key
#   2. Verify your sending domain (add SPF / DKIM records in DNS)
#   3. Set EMAIL_PROVIDER=resend and fill in the values below
EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=MemTrace

# App base URL — included in verification and password-reset links
APP_URL=https://app.yourdomain.com

# SMTP fallback (only used when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password

# ─── Backup ────────────────────────────────────────────────────────────────────
# Backup settings are configured at runtime via the UI (Settings → Backup).
# Backups are written to the path configured in the UI (default: /backups,
# which maps to ./backups/ on the host via the Docker volume mount).
